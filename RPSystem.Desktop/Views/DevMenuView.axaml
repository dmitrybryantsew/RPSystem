<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RPSystem.Desktop.ViewModels"
             x:Class="RPSystem.Desktop.Views.DevMenuView"
             x:DataType="vm:MainShellViewModel">
  <ScrollViewer>
    <StackPanel Spacing="14" Margin="12" MaxWidth="560" HorizontalAlignment="Center">
      <TextBlock Text="Developer Menu" FontSize="22" FontWeight="Bold" />
      <Button Content="Load Test Map" Command="{Binding ShowTestMapsCommand}" />
      <Button Content="World Context Editor" Command="{Binding ShowWorldContextViewCommand}" />
      <Button Content="Settings" Command="{Binding ShowSettingsViewCommand}" />
      <Button Content="Back To Menu" Command="{Binding ShowMainMenuCommand}" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
