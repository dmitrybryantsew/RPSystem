<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RPSystem.Desktop.ViewModels"
             x:Class="RPSystem.Desktop.Views.TestMapsView"
             x:DataType="vm:MainShellViewModel">
  <ScrollViewer>
    <StackPanel Spacing="14" Margin="12" MaxWidth="620" HorizontalAlignment="Center">
      <TextBlock Text="Load Test Map" FontSize="22" FontWeight="Bold" />
      <TextBlock Text="Test map loading (full version in Phase 07)" Foreground="Gray" />
      <Button Content="Back To Dev Menu" Command="{Binding ShowDevMenuCommand}" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
