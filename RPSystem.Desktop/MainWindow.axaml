<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:RPSystem.Desktop.Views"
        xmlns:vm="using:RPSystem.Desktop.ViewModels"
        x:Class="RPSystem.Desktop.MainWindow"
        x:DataType="vm:MainShellViewModel"
        Title="RPSystem" Width="1280" Height="800">
  <Grid>
    <views:MainMenuView IsVisible="{Binding IsMainMenuView}" />
    <views:WorldView IsVisible="{Binding IsWorldView}" />
    <views:SettingsView IsVisible="{Binding IsSettingsView}" />
    <views:WorldContextView IsVisible="{Binding IsWorldContextView}" />
    <views:GameOptionsView IsVisible="{Binding IsGameOptionsView}" />
    <views:DevMenuView IsVisible="{Binding IsDevMenuView}" />
    <views:TestMapsView IsVisible="{Binding IsTestMapsView}" />
  </Grid>
</Window>
