<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:RPSystem.Desktop.Converters"
             x:Class="RPSystem.Desktop.App">
  <Application.Styles>
    <FluentTheme />
  </Application.Styles>
  <Application.Resources>
    <converters:BoolToArrowConverter x:Key="BoolToArrowConverter" />
    <converters:BoolToStatusConverter x:Key="BoolToStatusConverter" />
    <converters:BoolToStatusTextConverter x:Key="BoolToStatusTextConverter" />
    <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
    <converters:NotNullConverter x:Key="NotNullConverter" />
  </Application.Resources>
</Application>
