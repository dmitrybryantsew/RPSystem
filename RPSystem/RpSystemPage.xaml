<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ChemCalculationAndManagementApp.RpSystemPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
    Title="RP System"
    BackgroundColor="#F6F7F9">

    <Grid RowDefinitions="Auto,*" Padding="8" RowSpacing="6">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="6">
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="{Binding WorldTitle}" FontAttributes="Bold" FontSize="18" TextColor="#17202A" />
                <Label Text="{Binding StatusText}" FontSize="12" TextColor="#607080" LineBreakMode="TailTruncation" />
            </VerticalStackLayout>

            <Button Grid.Column="1" Text="Menu" Command="{Binding ShowMainMenuCommand}" />
            <Button Grid.Column="2" Text="World" Command="{Binding ShowWorldViewCommand}" />
            <Button Grid.Column="3" Text="Game" Command="{Binding ShowGameOptionsViewCommand}" />
            <Button Grid.Column="4" Text="Dev" Command="{Binding ShowDevMenuCommand}" />
            <Button Grid.Column="5" Text="Settings" Command="{Binding ShowSettingsViewCommand}" />
            <Button Grid.Column="6" Text="Context" Command="{Binding ShowWorldContextViewCommand}" />
            <Button Grid.Column="7" Text="{Binding SliceModeText}" Command="{Binding ToggleSliceModeCommand}" />
            <Button Grid.Column="8" Text="-" Command="{Binding SliceDownCommand}" WidthRequest="44" />
            <Label Grid.Column="9" Text="{Binding SliceCoordinateText}" VerticalTextAlignment="Center" FontAttributes="Bold" TextColor="#17202A" />
            <Button Grid.Column="10" Text="+" Command="{Binding SliceUpCommand}" WidthRequest="44" />
            <Button Grid.Column="11" Text="Reset" Command="{Binding ResetWorldCommand}" />
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,330" ColumnSpacing="8">
            <Border Grid.Column="0" Stroke="#CCD3DB" StrokeThickness="1" BackgroundColor="#FFFFFF" Padding="8">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="6" />
                </Border.StrokeShape>
                <Grid>
                    <ScrollView IsVisible="{Binding IsMainMenuView}">
                        <VerticalStackLayout Spacing="14" Padding="12" MaximumWidthRequest="520" HorizontalOptions="Center">
                            <Label Text="RP System" FontSize="24" FontAttributes="Bold" TextColor="#17202A" />
                            <Label Text="{Binding ActiveViewText}" FontSize="12" TextColor="#607080" />
                            <Button Text="Continue Current World" Command="{Binding ShowWorldViewCommand}" />
                            <Button Text="Game Options" Command="{Binding ShowGameOptionsViewCommand}" />
                            <Button Text="Developer Menu" Command="{Binding ShowDevMenuCommand}" />
                            <Button Text="World Context Editor" Command="{Binding ShowWorldContextViewCommand}" />
                        </VerticalStackLayout>
                    </ScrollView>

                    <ScrollView IsVisible="{Binding IsGameOptionsView}">
                        <VerticalStackLayout Spacing="14" Padding="12" MaximumWidthRequest="560" HorizontalOptions="Center">
                            <Label Text="Game Options" FontSize="22" FontAttributes="Bold" TextColor="#17202A" />
                            <Border Stroke="#D7DEE6" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="10">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="6" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="Simulation Mode" FontAttributes="Bold" TextColor="#25313D" />
                                    <HorizontalStackLayout Spacing="8">
                                        <CheckBox IsChecked="{Binding UseLlm}" />
                                        <Label Text="{Binding LlmStateText}" VerticalTextAlignment="Center" />
                                    </HorizontalStackLayout>
                                    <Label Text="Local mode uses deterministic/default unit behavior. LLM mode can be enabled when you want deeper roleplay decisions." FontSize="12" TextColor="#607080" LineBreakMode="WordWrap" />
                                    <Label Text="Open Space Look Depth" FontAttributes="Bold" TextColor="#25313D" />
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <Slider Minimum="0" Maximum="20" Value="{Binding OpenSpaceLookDepth}" />
                                        <Label Grid.Column="1" Text="{Binding OpenSpaceLookDepth}" WidthRequest="34" HorizontalTextAlignment="End" VerticalTextAlignment="Center" />
                                    </Grid>
                                    <Label Text="Limits how many levels below open air are drawn. Deeper visible terrain is marked with ?." FontSize="12" TextColor="#607080" LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Border>
                            <Button Text="Controls And Model Settings" Command="{Binding ShowSettingsViewCommand}" />
                            <Button Text="Back To Menu" Command="{Binding ShowMainMenuCommand}" />
                        </VerticalStackLayout>
                    </ScrollView>

                    <ScrollView IsVisible="{Binding IsDevMenuView}">
                        <VerticalStackLayout Spacing="14" Padding="12" MaximumWidthRequest="560" HorizontalOptions="Center">
                            <Label Text="Developer Menu" FontSize="22" FontAttributes="Bold" TextColor="#17202A" />
                            <Button Text="Load Test Map" Command="{Binding ShowTestMapsCommand}" />
                            <Button Text="World Context Editor" Command="{Binding ShowWorldContextViewCommand}" />
                            <Button Text="Settings" Command="{Binding ShowSettingsViewCommand}" />
                            <Button Text="Back To Menu" Command="{Binding ShowMainMenuCommand}" />
                        </VerticalStackLayout>
                    </ScrollView>

                    <ScrollView IsVisible="{Binding IsTestMapsView}">
                        <VerticalStackLayout Spacing="14" Padding="12" MaximumWidthRequest="620" HorizontalOptions="Center">
                            <Label Text="Load Test Map" FontSize="22" FontAttributes="Bold" TextColor="#17202A" />
                            <Button Text="Starter Cavern: Unicorn And Changeling" Command="{Binding LoadCavernStarterTestMapCommand}" />
                            <Button Text="Glasshouse Outpost: Walls And Interaction" Command="{Binding LoadGlasshouseTestMapCommand}" />
                            <Button Text="Generated Ramp Cave: Multi-Level Walk Test" Command="{Binding LoadGeneratedRampCaveTestMapCommand}" />
                            <Button Text="Generated Ladder Cave: Multi-Level Climb Test" Command="{Binding LoadGeneratedLadderCaveTestMapCommand}" />
                            <Button Text="Pathfinding Stress: 10 Runners" Command="{Binding LoadPathfindingStress10TestMapCommand}" />
                            <Button Text="Pathfinding Stress: 50 Runners" Command="{Binding LoadPathfindingStress50TestMapCommand}" />
                            <Button Text="Pathfinding Stress: 100 Runners" Command="{Binding LoadPathfindingStress100TestMapCommand}" />
                            <Button Text="Pathfinding 3-Slice: Ramps And Flyers" Command="{Binding LoadVerticalPathfindingTestMapCommand}" />
                            <Button Text="Pathfinding Glass Atrium: Open Air Flight" Command="{Binding LoadGlassAtriumFlightTestMapCommand}" />
                            <Button Text="Back To Dev Menu" Command="{Binding ShowDevMenuCommand}" />
                        </VerticalStackLayout>
                    </ScrollView>

                    <Grid RowDefinitions="Auto,*" RowSpacing="6" IsVisible="{Binding IsWorldView}">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,Auto" ColumnSpacing="6">
                            <Button Text="-" Clicked="OnZoomOutClicked" WidthRequest="42" />
                            <Button Grid.Column="1" Text="+" Clicked="OnZoomInClicked" WidthRequest="42" />
                            <Button Grid.Column="2" Text="Center" Clicked="OnCenterMapClicked" />
                            <Button Grid.Column="3" Text="Look" Command="{Binding SetLookModeCommand}" />
                            <Button Grid.Column="4" Text="Move" Command="{Binding SetMoveModeCommand}" />
                            <Button Grid.Column="5" Text="Talk" Command="{Binding SetTalkModeCommand}" />
                            <Button Grid.Column="6" Text="Act" Command="{Binding SetInteractModeCommand}" />
                            <Button Grid.Column="7" Text="Use" Command="{Binding SetUseModeCommand}" />
                            <Button Grid.Column="8" Text="Atk" Command="{Binding SetAttackModeCommand}" />
                            <Label Grid.Column="9" Text="{Binding MapModeText}" VerticalTextAlignment="Center" FontAttributes="Bold" TextColor="#17202A" />
                            <Label Grid.Column="10" Text="{Binding SliceCoordinateText}" VerticalTextAlignment="Center" FontAttributes="Bold" TextColor="#17202A" />
                        </Grid>
                        <skia:SKCanvasView
                            Grid.Row="1"
                            x:Name="WorldCanvas"
                            EnableTouchEvents="True"
                            PaintSurface="OnWorldCanvasPaintSurface"
                            Touch="OnWorldCanvasTouch" />
                    </Grid>

                    <ScrollView IsVisible="{Binding IsSettingsView}">
                        <VerticalStackLayout Spacing="12" Padding="4">
                            <Label Text="RP Settings" FontSize="18" FontAttributes="Bold" TextColor="#17202A" />

                            <Border Stroke="#D7DEE6" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Simulation" FontAttributes="Bold" TextColor="#25313D" />
                                <HorizontalStackLayout Spacing="8">
                                    <CheckBox IsChecked="{Binding UseLlm}" />
                                    <Label Text="{Binding LlmStateText}" VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                                <Label Text="When LLM is off, non-player characters wait instead of requesting model actions." FontSize="12" TextColor="#607080" LineBreakMode="WordWrap" />
                                <Button Text="Load Models" Command="{Binding LoadModelsCommand}" HorizontalOptions="Start" />
                                <Picker Title="Model"
                                        ItemsSource="{Binding AvailableModels}"
                                        ItemDisplayBinding="{Binding DisplayName}"
                                        SelectedItem="{Binding SelectedModel}" />
                            </VerticalStackLayout>
                            </Border>

                            <Border Stroke="#D7DEE6" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Faction Profiles" FontAttributes="Bold" TextColor="#25313D" />
                                <Label Text="{Binding ActiveFactionProfileSummary}" FontSize="12" TextColor="#607080" />
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                    <Picker Title="Faction profile"
                                            ItemsSource="{Binding FactionProfiles}"
                                            ItemDisplayBinding="{Binding DisplayName}"
                                            SelectedItem="{Binding SelectedFactionProfile}" />
                                    <Button Grid.Column="1" Text="Add" Command="{Binding AddFactionProfileCommand}" />
                                    <Button Grid.Column="2" Text="Delete" Command="{Binding DeleteSelectedFactionProfileCommand}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                    <Entry Placeholder="Faction id" Text="{Binding FactionId}" />
                                    <Entry Grid.Column="1" Placeholder="Faction name" Text="{Binding FactionName}" />
                                    <Entry Grid.Column="2" Placeholder="Parent species/race" Text="{Binding FactionParentSpecies}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="6">
                                    <Picker Title="Visibility"
                                            ItemsSource="{Binding ContextModuleVisibilityOptions}"
                                            SelectedItem="{Binding FactionVisibility}" />
                                    <Entry Grid.Column="1" Placeholder="Applies to character/race/tag/faction:id" Text="{Binding FactionAppliesTo}" />
                                    <HorizontalStackLayout Grid.Column="2" Spacing="8">
                                        <CheckBox IsChecked="{Binding FactionIsEnabled}" />
                                        <Label Text="Enabled" VerticalTextAlignment="Center" />
                                    </HorizontalStackLayout>
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding FactionPublicDescription}"
                                            Placeholder="Public faction identity, common reputation, visible facts"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="90"
                                            MaxLength="60000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding FactionHiddenDoctrine}"
                                            Placeholder="Hidden/internal doctrine, private motives, secret strategy"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="90"
                                            MaxLength="60000" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding FactionCulture}"
                                            Placeholder="Culture, customs, internal norms"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="40000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding FactionHierarchy}"
                                            Placeholder="Hierarchy, ranks, command structure"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="40000" />
                                    <Editor Grid.Column="2"
                                            Text="{Binding FactionGoals}"
                                            Placeholder="Faction goals and long-term plans"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="40000" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding FactionTaboos}"
                                            Placeholder="Taboos, laws, restrictions"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="70"
                                            MaxLength="30000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding FactionOutsiderBehavior}"
                                            Placeholder="Default behavior toward outsiders"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="70"
                                            MaxLength="30000" />
                                    <Editor Grid.Column="2"
                                            Text="{Binding FactionMemberBehavior}"
                                            Placeholder="Default behavior toward members"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="70"
                                            MaxLength="30000" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding FactionAppearance}"
                                            Placeholder="Faction-specific appearance, tells, caste markers"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="40000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding FactionAnatomyOverrides}"
                                            Placeholder="Anatomy overrides: part = modifier"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="30000" />
                                    <Editor Grid.Column="2"
                                            Text="{Binding FactionTags}"
                                            Placeholder="Faction tags, one per line"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="20000" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding FactionMagicRules}"
                                            Placeholder="Faction magic/power rules"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="40000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding FactionResourceRules}"
                                            Placeholder="Faction resource/energy rules"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="40000" />
                                </Grid>
                                <Editor Text="{Binding FactionRolesText}"
                                        Placeholder="Roles: name | applies-to role/tag | description | stats hp=120/mana=50 | behavior | equipment | tags | on/off"
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="90"
                                        MaxLength="80000" />
                                <Editor Text="{Binding FactionAbilitiesText}"
                                        Placeholder="Abilities: id | name | target Self/Tile/Character | resource | mana | focus | stamina | damage | range | tick cost | cooldown | description | tags; use role:guard to restrict"
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="90"
                                        MaxLength="80000" />
                                <Editor Text="{Binding FactionRelationshipRulesText}"
                                        Placeholder="Relationships: target | type | trust | fear | dependency | loyalty | manipulation | suspicion | known secrets | handling rules"
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="90"
                                        MaxLength="80000" />
                                <Button Text="Save Faction" Command="{Binding SaveFactionProfileCommand}" HorizontalOptions="Start" />
                            </VerticalStackLayout>
                            </Border>

                            <Border Stroke="#D7DEE6" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Species Biology" FontAttributes="Bold" TextColor="#25313D" />
                                <Label Text="{Binding ActiveSpeciesTemplateSummary}" FontSize="12" TextColor="#607080" />
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                    <Picker Title="Species template"
                                            ItemsSource="{Binding SpeciesTemplates}"
                                            ItemDisplayBinding="{Binding Name}"
                                            SelectedItem="{Binding SelectedSpeciesTemplate}" />
                                    <Button Grid.Column="1" Text="Add" Command="{Binding AddSpeciesTemplateCommand}" />
                                    <Button Grid.Column="2" Text="Delete" Command="{Binding DeleteSelectedSpeciesTemplateCommand}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                    <Entry Placeholder="Template name" Text="{Binding SpeciesTemplateName}" />
                                    <Entry Grid.Column="1" Placeholder="Applies to race/tag" Text="{Binding SpeciesTemplateRace}" />
                                    <Picker Grid.Column="2"
                                            Title="Body type"
                                            ItemsSource="{Binding BodyTypeOptions}"
                                            SelectedItem="{Binding SpeciesTemplateBodyType}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding SpeciesBodyLanguageText}"
                                            Placeholder="Body language dictionary: cue = meaning"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="90"
                                            MaxLength="30000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding SpeciesVocalizationsText}"
                                            Placeholder="Vocalization dictionary: sound = meaning"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="90"
                                            MaxLength="30000" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding SpeciesDietRules}"
                                            Placeholder="Diet rules"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="30000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding SpeciesEnergyRules}"
                                            Placeholder="Energy rules"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="30000" />
                                    <Editor Grid.Column="2"
                                            Text="{Binding SpeciesMagicRules}"
                                            Placeholder="Magic rules"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="30000" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding SpeciesAnatomyModifiersText}"
                                            Placeholder="Anatomy modifiers: part = modifier"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="30000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding SpeciesTagsText}"
                                            Placeholder="Tags, one per line"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="12000" />
                                </Grid>
                                <Button Text="Save Species Template" Command="{Binding SaveSpeciesTemplateCommand}" HorizontalOptions="Start" />
                            </VerticalStackLayout>
                            </Border>

                            <Border Stroke="#D7DEE6" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Context Modules" FontAttributes="Bold" TextColor="#25313D" />
                                <Label Text="{Binding ActiveContextModuleSummary}" FontSize="12" TextColor="#607080" />
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                    <Picker Title="Module"
                                            ItemsSource="{Binding ContextModules}"
                                            ItemDisplayBinding="{Binding DisplayName}"
                                            SelectedItem="{Binding SelectedContextModule}" />
                                    <Button Grid.Column="1" Text="Add" Command="{Binding AddContextModuleCommand}" />
                                    <Button Grid.Column="2" Text="Delete" Command="{Binding DeleteSelectedContextModuleCommand}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                    <Entry Placeholder="Module name" Text="{Binding ContextModuleName}" />
                                    <Picker Grid.Column="1"
                                            Title="Type"
                                            ItemsSource="{Binding ContextModuleTypeOptions}"
                                            SelectedItem="{Binding ContextModuleType}" />
                                    <Picker Grid.Column="2"
                                            Title="Visibility"
                                            ItemsSource="{Binding ContextModuleVisibilityOptions}"
                                            SelectedItem="{Binding ContextModuleVisibility}" />
                                </Grid>
                                <Grid ColumnDefinitions="120,*,*,Auto" ColumnSpacing="6">
                                    <Entry Placeholder="Priority" Keyboard="Numeric" Text="{Binding ContextModulePriority}" />
                                    <Entry Grid.Column="1" Placeholder="Source label" Text="{Binding ContextModuleSourceLabel}" />
                                    <Entry Grid.Column="2" Placeholder="Applies to character/race/tag" Text="{Binding ContextModuleAppliesTo}" />
                                    <HorizontalStackLayout Grid.Column="3" Spacing="8">
                                        <CheckBox IsChecked="{Binding ContextModuleIsEnabled}" />
                                        <Label Text="Enabled" VerticalTextAlignment="Center" />
                                    </HorizontalStackLayout>
                                </Grid>
                                <Editor Text="{Binding ContextModuleText}"
                                        Placeholder="Focused module text: one behavior protocol, ability ruleset, lore block, scene pacing rule, continuity rule, or import note."
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="220"
                                        MaxLength="1000000" />
                                <HorizontalStackLayout Spacing="6">
                                    <Button Text="Save Module" Command="{Binding SaveContextModuleCommand}" />
                                    <Button Text="Scaffold Standard Sections" Command="{Binding ScaffoldStandardContextSectionsCommand}" />
                                    <Button Text="Duplicate" Command="{Binding DuplicateSelectedContextModuleCommand}" />
                                    <Button Text="From Legacy Text" Command="{Binding CreateModuleFromLegacyContextCommand}" />
                                    <Button Text="Clear Legacy Text" Command="{Binding ClearLegacyContextTextCommand}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            </Border>

                            <Border Stroke="#D7DEE6" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="World Files" FontAttributes="Bold" TextColor="#25313D" />
                                <HorizontalStackLayout Spacing="6">
                                    <Button Text="Save" Command="{Binding SaveWorldCommand}" />
                                    <Button Text="Load" Command="{Binding LoadWorldCommand}" />
                                    <Button Text="Import Markdown" Command="{Binding ImportMarkdownCommand}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            </Border>

                            <Border Stroke="#D7DEE6" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="World Context" FontAttributes="Bold" TextColor="#25313D" />
                                <Label Text="{Binding ActiveWorldContextSummary}" TextColor="#607080" />
                                <Picker Title="Context"
                                        ItemsSource="{Binding WorldContexts}"
                                        ItemDisplayBinding="{Binding DisplayName}"
                                        SelectedItem="{Binding SelectedWorldContext}" />
                                <HorizontalStackLayout Spacing="8">
                                    <CheckBox IsChecked="{Binding WorldContextIsEnabled}" />
                                    <Label Text="Inject selected context into NPC turns" VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                                <Button Text="Edit World Context" Command="{Binding ShowWorldContextViewCommand}" HorizontalOptions="Start" />
                            </VerticalStackLayout>
                            </Border>

                            <Border Stroke="#D7DEE6" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Player" FontAttributes="Bold" TextColor="#25313D" />
                                <Picker Title="Selected Character"
                                        ItemsSource="{Binding Characters}"
                                        ItemDisplayBinding="{Binding Name}"
                                        SelectedItem="{Binding SelectedCharacter}" />
                                <Button Text="Set Selected As Player" Command="{Binding SetSelectedAsPlayerCommand}" HorizontalOptions="Start" />
                                <Label Text="{Binding PlayerCharacterText}" TextColor="#25313D" />
                            </VerticalStackLayout>
                            </Border>

                            <Border Stroke="#D7DEE6" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="View" FontAttributes="Bold" TextColor="#25313D" />
                                <Label Text="{Binding ActiveViewText}" TextColor="#607080" />
                                <Label Text="{Binding MapModeText}" TextColor="#607080" />
                                <HorizontalStackLayout Spacing="6">
                                    <Button Text="Look" Command="{Binding SetLookModeCommand}" />
                                    <Button Text="Move" Command="{Binding SetMoveModeCommand}" />
                                    <Button Text="Talk" Command="{Binding SetTalkModeCommand}" />
                                    <Button Text="Interact" Command="{Binding SetInteractModeCommand}" />
                                    <Button Text="Use" Command="{Binding SetUseModeCommand}" />
                                    <Button Text="Attack" Command="{Binding SetAttackModeCommand}" />
                                </HorizontalStackLayout>
                                <Button Text="{Binding SliceModeText}" Command="{Binding ToggleSliceModeCommand}" HorizontalOptions="Start" />
                                <HorizontalStackLayout Spacing="6">
                                    <Button Text="Slice -" Command="{Binding SliceDownCommand}" />
                                    <Label Text="{Binding SliceCoordinateText}" VerticalTextAlignment="Center" FontAttributes="Bold" />
                                    <Button Text="Slice +" Command="{Binding SliceUpCommand}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            </Border>

                            <Border Stroke="#D7DEE6" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,*,*" RowSpacing="8" ColumnSpacing="8">
                                <Label Text="Controls" FontAttributes="Bold" TextColor="#25313D" />
                                <Button Grid.Column="2" Text="Defaults" Command="{Binding ResetControlsCommand}" />
                                <Entry Grid.Row="1" Placeholder="North" Text="{Binding MoveNorthKey}" />
                                <Entry Grid.Row="1" Grid.Column="1" Placeholder="South" Text="{Binding MoveSouthKey}" />
                                <Entry Grid.Row="1" Grid.Column="2" Placeholder="West" Text="{Binding MoveWestKey}" />
                                <Entry Grid.Row="2" Placeholder="East" Text="{Binding MoveEastKey}" />
                                <Entry Grid.Row="2" Grid.Column="1" Placeholder="Up" Text="{Binding MoveUpKey}" />
                                <Entry Grid.Row="2" Grid.Column="2" Placeholder="Down" Text="{Binding MoveDownKey}" />
                                <Entry Grid.Row="3" Placeholder="Wait" Text="{Binding WaitKey}" />
                                <Entry Grid.Row="3" Grid.Column="1" Placeholder="Look mode" Text="{Binding LookModeKey}" />
                                <Entry Grid.Row="3" Grid.Column="2" Placeholder="Move mode" Text="{Binding MoveModeKey}" />
                                <Label Grid.Row="4" Grid.ColumnSpan="3" Text="Use names like W, Space, PageUp, Left, NumberPad8." FontSize="12" TextColor="#607080" />
                            </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </ScrollView>

                    <ScrollView IsVisible="{Binding IsWorldContextView}">
                        <VerticalStackLayout Spacing="12" Padding="4">
                            <Label Text="World Context" FontSize="18" FontAttributes="Bold" TextColor="#17202A" />
                            <Label Text="{Binding ActiveWorldContextSummary}" FontSize="12" TextColor="#607080" />

                            <Border Stroke="#D7DEE6" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                    <Picker Title="Context"
                                            ItemsSource="{Binding WorldContexts}"
                                            ItemDisplayBinding="{Binding DisplayName}"
                                            SelectedItem="{Binding SelectedWorldContext}" />
                                    <Button Grid.Column="1" Text="Add" Command="{Binding AddWorldContextCommand}" />
                                    <Button Grid.Column="2" Text="Delete" Command="{Binding DeleteSelectedWorldContextCommand}" />
                                </Grid>

                                <Entry Placeholder="Context name" Text="{Binding WorldContextName}" />
                                <HorizontalStackLayout Spacing="8">
                                    <CheckBox IsChecked="{Binding WorldContextIsEnabled}" />
                                    <Label Text="Enabled for simulation and LLM snapshots" VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                                <Editor Text="{Binding WorldContextRulesText}"
                                        Placeholder="World rules, setting constraints, character feature rules, magic limits, tone, physics assumptions, or other global context."
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="520"
                                        MaxLength="1000000" />
                                <HorizontalStackLayout Spacing="6">
                                    <Button Text="Save Context" Command="{Binding SaveWorldContextEditsCommand}" />
                                    <Button Text="Back To World" Command="{Binding ShowWorldViewCommand}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            </Border>

                            <Border Stroke="#D7DEE6" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Context Characters" FontAttributes="Bold" TextColor="#25313D" />
                                <Label Text="{Binding ActiveContextCharacterSummary}" FontSize="12" TextColor="#607080" />
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                    <Picker Title="Character profile"
                                            ItemsSource="{Binding ContextCharacters}"
                                            ItemDisplayBinding="{Binding DisplayName}"
                                            SelectedItem="{Binding SelectedContextCharacter}" />
                                    <Button Grid.Column="1" Text="Add" Command="{Binding AddContextCharacterCommand}" />
                                    <Button Grid.Column="2" Text="Delete" Command="{Binding DeleteSelectedContextCharacterCommand}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                    <Entry Placeholder="Name" Text="{Binding ContextCharacterName}" />
                                    <Entry Grid.Column="1" Placeholder="Archetype" Text="{Binding ContextCharacterArchetype}" />
                                    <Entry Grid.Column="2" Placeholder="Race" Text="{Binding ContextCharacterRace}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                    <Picker Title="Profile visibility"
                                            ItemsSource="{Binding ContextModuleVisibilityOptions}"
                                            SelectedItem="{Binding ContextCharacterVisibility}" />
                                    <Entry Grid.Column="1"
                                           Placeholder="Known-to target: character/race/tag"
                                           Text="{Binding ContextCharacterAppliesTo}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                    <Picker Title="Body type"
                                            ItemsSource="{Binding BodyTypeOptions}"
                                            SelectedItem="{Binding ContextCharacterBodyType}" />
                                    <Entry Grid.Column="1" Placeholder="Faction id" Text="{Binding ContextCharacterFactionId}" />
                                    <HorizontalStackLayout Grid.Column="2" Spacing="8">
                                        <CheckBox IsChecked="{Binding ContextCharacterIsNamed}" />
                                        <Label Text="Named" VerticalTextAlignment="Center" />
                                    </HorizontalStackLayout>
                                </Grid>
                                <Entry Placeholder="Role in world" Text="{Binding ContextCharacterRole}" />
                                <Editor Text="{Binding ContextCharacterPersonality}"
                                        Placeholder="Personality traits, habits, temperament, values"
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="80"
                                        MaxLength="20000" />
                                <Editor Text="{Binding ContextCharacterStory}"
                                        Placeholder="Backstory, relationships, secrets, notable events"
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="120"
                                        MaxLength="100000" />
                                <Editor Text="{Binding ContextCharacterAbilities}"
                                        Placeholder="Abilities, skills, magic, combat style, tools"
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="80"
                                        MaxLength="30000" />
                                <Label Text="Behavior Protocol" FontAttributes="Bold" TextColor="#25313D" />
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding ContextCharacterSpeechStyle}"
                                            Placeholder="Speech style"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="70"
                                            MaxLength="12000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding ContextCharacterFirstEncounter}"
                                            Placeholder="First encounter behavior"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="70"
                                            MaxLength="12000" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding ContextCharacterNegotiation}"
                                            Placeholder="Negotiation style"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="70"
                                            MaxLength="12000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding ContextCharacterRelationshipHandling}"
                                            Placeholder="Relationship handling"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="70"
                                            MaxLength="12000" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding ContextCharacterEscalation}"
                                            Placeholder="Escalation pattern"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="70"
                                            MaxLength="12000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding ContextCharacterDeEscalation}"
                                            Placeholder="De-escalation pattern"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="70"
                                            MaxLength="12000" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding ContextCharacterDeception}"
                                            Placeholder="Deception mode"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="70"
                                            MaxLength="12000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding ContextCharacterCombatPreferences}"
                                            Placeholder="Combat preferences"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="70"
                                            MaxLength="12000" />
                                    <Editor Grid.Column="2"
                                            Text="{Binding ContextCharacterCapturePreferences}"
                                            Placeholder="Capture preferences"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="70"
                                            MaxLength="12000" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding ContextCharacterGoal}"
                                            Placeholder="Current goal"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="70"
                                            MaxLength="10000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding ContextCharacterLifeGoal}"
                                            Placeholder="Long-term story goal"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="70"
                                            MaxLength="10000" />
                                </Grid>
                                <Entry Placeholder="Tags, comma separated" Text="{Binding ContextCharacterTags}" />
                                <HorizontalStackLayout Spacing="6">
                                    <Button Text="Save Character" Command="{Binding SaveContextCharacterCommand}" />
                                    <Button Text="From Selected" Command="{Binding CreateContextCharacterFromSelectedCommand}" />
                                    <Button Text="Spawn In World" Command="{Binding SpawnSelectedContextCharacterCommand}" />
                                </HorizontalStackLayout>

                                <Label Text="Structured Abilities" FontAttributes="Bold" TextColor="#25313D" />
                                <Label Text="{Binding ActiveAbilitySummary}" FontSize="12" TextColor="#607080" />
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                    <Picker Title="Ability"
                                            ItemsSource="{Binding ContextAbilities}"
                                            ItemDisplayBinding="{Binding Name}"
                                            SelectedItem="{Binding SelectedContextAbility}" />
                                    <Button Grid.Column="1" Text="Add" Command="{Binding AddContextAbilityCommand}" />
                                    <Button Grid.Column="2" Text="Delete" Command="{Binding DeleteSelectedContextAbilityCommand}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                    <Entry Placeholder="Ability id" Text="{Binding ContextAbilityId}" />
                                    <Entry Grid.Column="1" Placeholder="Ability name" Text="{Binding ContextAbilityName}" />
                                    <Picker Grid.Column="2"
                                            Title="Target"
                                            ItemsSource="{Binding AbilityTargetKindOptions}"
                                            SelectedItem="{Binding ContextAbilityTargetKind}" />
                                </Grid>
                                <Editor Text="{Binding ContextAbilityDescription}"
                                        Placeholder="Ability description"
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="70"
                                        MaxLength="20000" />
                                <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="6">
                                    <Picker Title="Damage"
                                            ItemsSource="{Binding AbilityDamageTypeOptions}"
                                            SelectedItem="{Binding ContextAbilityDamageType}" />
                                    <Picker Grid.Column="1"
                                            Title="Resource"
                                            ItemsSource="{Binding AbilityResourceOptions}"
                                            SelectedItem="{Binding ContextAbilityResource}" />
                                    <Entry Grid.Column="2" Placeholder="Range" Keyboard="Numeric" Text="{Binding ContextAbilityRange}" />
                                    <Entry Grid.Column="3" Placeholder="Tick cost" Keyboard="Numeric" Text="{Binding ContextAbilityTickCost}" />
                                    <Entry Grid.Column="4" Placeholder="Cooldown" Keyboard="Numeric" Text="{Binding ContextAbilityCooldownTicks}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="6">
                                    <Entry Placeholder="Mana cost" Keyboard="Numeric" Text="{Binding ContextAbilityManaCost}" />
                                    <Entry Grid.Column="1" Placeholder="Focus cost" Keyboard="Numeric" Text="{Binding ContextAbilityFocusCost}" />
                                    <Entry Grid.Column="2" Placeholder="Stamina cost" Keyboard="Numeric" Text="{Binding ContextAbilityStaminaCost}" />
                                    <Entry Grid.Column="3" Placeholder="Damage amount" Keyboard="Numeric" Text="{Binding ContextAbilityDamage}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding ContextAbilityRangeText}"
                                            Placeholder="Range details"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="70"
                                            MaxLength="12000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding ContextAbilityTargetRules}"
                                            Placeholder="Target rules"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="70"
                                            MaxLength="12000" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding ContextAbilityConstraints}"
                                            Placeholder="Constraints"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="20000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding ContextAbilityWorldEffect}"
                                            Placeholder="World effect"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="20000" />
                                    <Editor Grid.Column="2"
                                            Text="{Binding ContextAbilityNarrativeEffect}"
                                            Placeholder="Narrative effect"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="20000" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding ContextAbilityAllowedUsage}"
                                            Placeholder="Allowed usage"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="70"
                                            MaxLength="12000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding ContextAbilityForbiddenUsage}"
                                            Placeholder="Forbidden usage"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="70"
                                            MaxLength="12000" />
                                    <Editor Grid.Column="2"
                                            Text="{Binding ContextAbilityTagsText}"
                                            Placeholder="Tags, one per line"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="70"
                                            MaxLength="12000" />
                                </Grid>
                                <Button Text="Save Ability" Command="{Binding SaveContextAbilityCommand}" HorizontalOptions="Start" />

                                <Label Text="Relationship Dynamics" FontAttributes="Bold" TextColor="#25313D" />
                                <Label Text="{Binding ActiveRelationshipRuleSummary}" FontSize="12" TextColor="#607080" />
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                    <Picker Title="Relationship rule"
                                            ItemsSource="{Binding RelationshipRules}"
                                            ItemDisplayBinding="{Binding TargetNameOrTag}"
                                            SelectedItem="{Binding SelectedRelationshipRule}" />
                                    <Button Grid.Column="1" Text="Add" Command="{Binding AddRelationshipRuleCommand}" />
                                    <Button Grid.Column="2" Text="Delete" Command="{Binding DeleteSelectedRelationshipRuleCommand}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                    <Entry Placeholder="Target name/race/tag" Text="{Binding RelationshipTargetNameOrTag}" />
                                    <Picker Grid.Column="1"
                                            Title="Relationship type"
                                            ItemsSource="{Binding RelationshipTypeOptions}"
                                            SelectedItem="{Binding RelationshipType}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="6">
                                    <Entry Placeholder="Trust" Keyboard="Numeric" Text="{Binding RelationshipTrust}" />
                                    <Entry Grid.Column="1" Placeholder="Fear" Keyboard="Numeric" Text="{Binding RelationshipFear}" />
                                    <Entry Grid.Column="2" Placeholder="Dependency" Keyboard="Numeric" Text="{Binding RelationshipDependency}" />
                                    <Entry Grid.Column="3" Placeholder="Loyalty" Keyboard="Numeric" Text="{Binding RelationshipLoyalty}" />
                                    <Entry Grid.Column="4" Placeholder="Manipulation" Keyboard="Numeric" Text="{Binding RelationshipManipulation}" />
                                    <Entry Grid.Column="5" Placeholder="Suspicion" Keyboard="Numeric" Text="{Binding RelationshipSuspicion}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding RelationshipKnownSecretsText}"
                                            Placeholder="Known secrets, one per line"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="30000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding RelationshipHandlingRules}"
                                            Placeholder="Handling rules"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="30000" />
                                </Grid>
                                <Button Text="Save Relationship Rule" Command="{Binding SaveRelationshipRuleCommand}" HorizontalOptions="Start" />
                            </VerticalStackLayout>
                            </Border>

                            <Border Stroke="#D7DEE6" StrokeThickness="1" BackgroundColor="#F8FAFC" Padding="10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Scene, Environment, Continuity" FontAttributes="Bold" TextColor="#25313D" />
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                    <Picker Title="Scene phase"
                                            ItemsSource="{Binding ScenePhaseOptions}"
                                            SelectedItem="{Binding ScenePhase}" />
                                    <Entry Grid.Column="1" Placeholder="Escalation budget" Keyboard="Numeric" Text="{Binding SceneEscalationBudget}" />
                                    <Entry Grid.Column="2" Placeholder="Escalation rate/tick" Keyboard="Numeric" Text="{Binding SceneEscalationRate}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding SceneActiveThreadsText}"
                                            Placeholder="Active threads, one per line"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="90"
                                            MaxLength="30000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding SceneForeshadowedText}"
                                            Placeholder="Foreshadowed elements"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="90"
                                            MaxLength="30000" />
                                    <Editor Grid.Column="2"
                                            Text="{Binding SceneUnresolvedPromisesText}"
                                            Placeholder="Unresolved promises"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="90"
                                            MaxLength="30000" />
                                    <Editor Grid.Column="3"
                                            Text="{Binding SceneMajorPrerequisitesText}"
                                            Placeholder="Major action prerequisites"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="90"
                                            MaxLength="30000" />
                                </Grid>
                                <Editor Text="{Binding EnvironmentInteractiveObjectsText}"
                                        Placeholder="Interactive objects: name | tile/tag | interaction | world effect | narrative effect | constraints"
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="100"
                                        MaxLength="60000" />
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding EnvironmentTellsText}"
                                            Placeholder="Environmental tells"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="30000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding EnvironmentHazardsText}"
                                            Placeholder="Hazards"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="30000" />
                                    <Editor Grid.Column="2"
                                            Text="{Binding EnvironmentTerrainAffordancesText}"
                                            Placeholder="Terrain affordances"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="30000" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding EnvironmentCluesText}"
                                            Placeholder="Clues"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="30000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding EnvironmentDomainOwnerRulesText}"
                                            Placeholder="Domain-owner awareness/control rules"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="30000" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding ContinuityPhysicalChangesText}"
                                            Placeholder="Persistent physical changes"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="30000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding ContinuityEmotionalChangesText}"
                                            Placeholder="Emotional state changes"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="30000" />
                                    <Editor Grid.Column="2"
                                            Text="{Binding ContinuityRelationshipChangesText}"
                                            Placeholder="Relationship changes"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="30000" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="6">
                                    <Editor Text="{Binding ContinuityFlagsText}"
                                            Placeholder="Flags"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="30000" />
                                    <Editor Grid.Column="1"
                                            Text="{Binding ContinuityTriggersText}"
                                            Placeholder="Triggers"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="30000" />
                                    <Editor Grid.Column="2"
                                            Text="{Binding ContinuityIrreversibleEventsText}"
                                            Placeholder="Irreversible events"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="30000" />
                                    <Editor Grid.Column="3"
                                            Text="{Binding ContinuityPendingConsequencesText}"
                                            Placeholder="Pending consequences"
                                            AutoSize="TextChanges"
                                            MinimumHeightRequest="80"
                                            MaxLength="30000" />
                                </Grid>
                                <Button Text="Save Scene, Environment, Continuity" Command="{Binding SaveSceneEnvironmentContinuityCommand}" HorizontalOptions="Start" />
                            </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>
            </Border>

            <ScrollView Grid.Column="1">
            <VerticalStackLayout Spacing="8">
                <Grid Grid.Row="0" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                    <Picker Grid.Row="0"
                            Title="Character"
                            ItemsSource="{Binding Characters}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedCharacter}" />

                    <Label Grid.Row="1"
                           Text="{Binding SelectedCharacterSummary}"
                           FontSize="13"
                           TextColor="#25313D"
                           LineBreakMode="WordWrap" />

                    <Grid Grid.Row="2" ColumnDefinitions="*,*,Auto" ColumnSpacing="6">
                        <Button Text="Tick" Command="{Binding StepTickCommand}" />
                        <Button Grid.Column="1" Text="Run 5" Command="{Binding RunFiveTicksCommand}" />
                        <Button Grid.Column="2" Text="Stop" Command="{Binding StopCommand}" />
                    </Grid>
                </Grid>

                <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="4">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                        <Label Text="{Binding PlayerCharacterText}" VerticalTextAlignment="Center" FontAttributes="Bold" TextColor="#17202A" />
                        <Button Grid.Column="1" Text="Set" Command="{Binding SetSelectedAsPlayerCommand}" />
                    </Grid>
                    <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="78,*" RowSpacing="3" ColumnSpacing="8">
                        <Label Text="{Binding PlayerHealthText}" FontSize="11" TextColor="#25313D" />
                        <ProgressBar Grid.Column="1" Progress="{Binding PlayerHealthProgress}" ProgressColor="#C74343" />
                        <Label Grid.Row="1" Text="{Binding PlayerManaText}" FontSize="11" TextColor="#25313D" />
                        <ProgressBar Grid.Row="1" Grid.Column="1" Progress="{Binding PlayerManaProgress}" ProgressColor="#3E73C8" />
                        <Label Grid.Row="2" Text="{Binding PlayerFocusText}" FontSize="11" TextColor="#25313D" />
                        <ProgressBar Grid.Row="2" Grid.Column="1" Progress="{Binding PlayerFocusProgress}" ProgressColor="#8A63C7" />
                        <Label Grid.Row="3" Text="{Binding PlayerStaminaText}" FontSize="11" TextColor="#25313D" />
                        <ProgressBar Grid.Row="3" Grid.Column="1" Progress="{Binding PlayerStaminaProgress}" ProgressColor="#3E9B62" />
                    </Grid>
                    <Grid Grid.Row="2" ColumnDefinitions="*,44,*" ColumnSpacing="4">
                        <Button Grid.Column="1" Text="W" Command="{Binding MovePlayerNorthCommand}" />
                    </Grid>
                    <Grid Grid.Row="3" ColumnDefinitions="44,44,44,*,44,44" ColumnSpacing="4">
                        <Button Text="A" Command="{Binding MovePlayerWestCommand}" />
                        <Button Grid.Column="1" Text="S" Command="{Binding MovePlayerSouthCommand}" />
                        <Button Grid.Column="2" Text="D" Command="{Binding MovePlayerEastCommand}" />
                        <Button Grid.Column="4" Text="Up" Command="{Binding MovePlayerUpCommand}" />
                        <Button Grid.Column="5" Text="Dn" Command="{Binding MovePlayerDownCommand}" />
                    </Grid>
                    <Grid Grid.Row="4" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Button Text="Look" Command="{Binding LookAtPlayerTileCommand}" />
                        <Label Grid.Column="1" Text="WASD keys also move the player on Windows." FontSize="11" TextColor="#607080" VerticalTextAlignment="Center" />
                    </Grid>
                </Grid>

                <Grid Grid.Row="2" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
                    <Label Text="Look" FontAttributes="Bold" TextColor="#17202A" />
                    <ScrollView Grid.Row="1" MaximumHeightRequest="110">
                        <Label Text="{Binding SelectedTileInfo}" FontSize="12" TextColor="#25313D" LineBreakMode="WordWrap" />
                    </ScrollView>
                    <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="4">
                        <Button Text="Move Here" Command="{Binding MoveToInspectedTileCommand}" FontSize="12" />
                        <Button Grid.Column="1" Text="Talk" Command="{Binding TalkToInspectedCharacterCommand}" FontSize="12" />
                        <Button Grid.Column="2" Text="Interact" Command="{Binding InteractWithInspectedTileCommand}" FontSize="12" />
                    </Grid>
                    <Grid Grid.Row="3" ColumnDefinitions="*,*,*" ColumnSpacing="4">
                        <Button Text="Use Held" Command="{Binding UseHeldItemOnInspectedTileCommand}" FontSize="12" />
                        <Button Grid.Column="1" Text="Attack" Command="{Binding AttackInspectedTargetCommand}" FontSize="12" />
                        <Button Grid.Column="2" Text="Fireball" Command="{Binding CastFireballAtInspectedTileCommand}" FontSize="12" />
                    </Grid>
                </Grid>

                <Grid Grid.Row="3" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
                    <Label Text="{Binding InventorySummary}" FontAttributes="Bold" TextColor="#17202A" />
                    <Picker Grid.Row="1"
                            Title="Ground item"
                            ItemsSource="{Binding GroundItems}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedGroundItem}" />
                    <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="4">
                        <Button Text="Pick Up" Command="{Binding PickUpSelectedGroundItemCommand}" FontSize="12" />
                        <Button Grid.Column="1" Text="Hold" Command="{Binding HoldSelectedInventoryItemCommand}" FontSize="12" />
                        <Button Grid.Column="2" Text="Drop" Command="{Binding DropSelectedInventoryItemCommand}" FontSize="12" />
                    </Grid>
                    <Picker Grid.Row="3"
                            Title="Inventory item"
                            ItemsSource="{Binding InventoryItems}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedInventoryItem}" />
                </Grid>

                <CollectionView Grid.Row="4" ItemsSource="{Binding EventLog}" HeightRequest="220">
                    <CollectionView.EmptyView>
                        <Label Text="No events yet." TextColor="#7A8793" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Label Text="{Binding .}" FontSize="12" TextColor="#25313D" Margin="0,0,0,6" LineBreakMode="WordWrap" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid Grid.Row="5" RowDefinitions="Auto,Auto" RowSpacing="6">
                    <Editor Grid.Row="0"
                            Text="{Binding PlayerInput}"
                            Placeholder="Narrator event or world note"
                            AutoSize="TextChanges"
                            MinimumHeightRequest="72"
                            MaxLength="2000" />
                    <Button Grid.Row="1" Text="Add Narrator Event" Command="{Binding AddPlayerInputCommand}" />
                </Grid>
            </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
