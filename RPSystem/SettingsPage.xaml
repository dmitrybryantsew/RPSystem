<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:ChemCalculationAndManagementApp.ViewModels"
             x:Class="ChemCalculationAndManagementApp.SettingsPage"
             x:DataType="viewmodels:SettingsViewModel"
             Title="Settings">

    <Grid RowDefinitions="Auto,*" Padding="20">
        <!-- Settings Tabs -->
        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
            <Button Text="General"
                    Command="{Binding SelectTabCommand}"
                    CommandParameter="0">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsGeneralTabSelected}" Value="True">
                        <Setter Property="BackgroundColor" Value="#DDE6FF"/>
                        <Setter Property="TextColor" Value="#1A3A7A"/>
                    </DataTrigger>
                </Button.Triggers>
            </Button>
            <Button Text="Camera"
                    Grid.Column="1"
                    Command="{Binding SelectTabCommand}"
                    CommandParameter="1">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsCameraTabSelected}" Value="True">
                        <Setter Property="BackgroundColor" Value="#DDE6FF"/>
                        <Setter Property="TextColor" Value="#1A3A7A"/>
                    </DataTrigger>
                </Button.Triggers>
            </Button>
            <Button Text="AI"
                    Grid.Column="2"
                    Command="{Binding SelectTabCommand}"
                    CommandParameter="2">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsAiTabSelected}" Value="True">
                        <Setter Property="BackgroundColor" Value="#DDE6FF"/>
                        <Setter Property="TextColor" Value="#1A3A7A"/>
                    </DataTrigger>
                </Button.Triggers>
            </Button>
            <Button Text="Integrations"
                    Grid.Column="3"
                    Command="{Binding SelectTabCommand}"
                    CommandParameter="3">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsIntegrationsTabSelected}" Value="True">
                        <Setter Property="BackgroundColor" Value="#DDE6FF"/>
                        <Setter Property="TextColor" Value="#1A3A7A"/>
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="20" VerticalOptions="Start">
                <!-- General -->
                <VerticalStackLayout IsVisible="{Binding IsGeneralTabSelected}" Spacing="20">
                    <Frame BackgroundColor="#F5F5F5" Padding="15" CornerRadius="10">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Debug Settings"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#333333"/>

                            <BoxView HeightRequest="1" Color="#CCCCCC"/>

                            <!-- Debug Mode Toggle -->
                            <HorizontalStackLayout Spacing="15">
                                <Switch IsToggled="{Binding DebugEnabled}"
                                        OnColor="Green"
                                        VerticalOptions="Center"/>
                                <VerticalStackLayout Spacing="5" HorizontalOptions="FillAndExpand" VerticalOptions="Center">
                                    <Label Text="Enable Debug Mode"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#333333"/>
                                    <Label Text="Shows detailed error information and processing logs"
                                           FontSize="13"
                                           TextColor="#666666"
                                           LineBreakMode="WordWrap"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>

                            <!-- Debug Status Indicator -->
                            <Frame Padding="10"
                                   BackgroundColor="{OnPlatform Android=#E8F5E9, iOS=#E8F5E9, Default=#F0F0F0}"
                                   CornerRadius="5"
                                   Margin="0,10,0,0">
                                <HorizontalStackLayout Spacing="10">
                                    <Label Text="&#x2699;" FontSize="20"/>
                                    <Label Text="{Binding DebugEnabled, Converter={StaticResource BoolToStatusTextConverter}}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Frame>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame BackgroundColor="#E3F2FD" Padding="15" CornerRadius="10">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="ℹ️ About Debug Mode"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#1976D2"/>
                            <Label Text="When enabled, debug mode provides:"
                                   FontSize="14"
                                   TextColor="#333333"/>
                            <Label Text="• Detailed processing logs"
                                   FontSize="13"
                                   TextColor="#666666"
                                   Margin="20,0,0,0"/>
                            <Label Text="• File-by-file progress information"
                                   FontSize="13"
                                   TextColor="#666666"
                                   Margin="20,0,0,0"/>
                            <Label Text="• Full error messages and stack traces"
                                   FontSize="13"
                                   TextColor="#666666"
                                   Margin="20,0,0,0"/>
                            <Label Text="• Request/response timing information"
                                   FontSize="13"
                                   TextColor="#666666"
                                   Margin="20,0,0,0"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame BackgroundColor="#F5F5F5" Padding="15" CornerRadius="10">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Chat Color Scheme"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#333333"/>
                            <BoxView HeightRequest="1" Color="#CCCCCC"/>
                            <RadioButton Content="Classic Blue (default)"
                                         IsChecked="{Binding IsColorSchemeClassic}"
                                         GroupName="ChatColorSchemeGroup"/>
                            <RadioButton Content="Forest"
                                         IsChecked="{Binding IsColorSchemeForest}"
                                         GroupName="ChatColorSchemeGroup"/>
                            <RadioButton Content="Sunset"
                                         IsChecked="{Binding IsColorSchemeSunset}"
                                         GroupName="ChatColorSchemeGroup"/>
                            <RadioButton Content="Monochrome"
                                         IsChecked="{Binding IsColorSchemeMono}"
                                         GroupName="ChatColorSchemeGroup"/>
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>

                <!-- Camera -->
                <VerticalStackLayout IsVisible="{Binding IsCameraTabSelected}" Spacing="20">
                    <Frame BackgroundColor="#F5F5F5" Padding="15" CornerRadius="10">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Camera &amp; Storage"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#333333"/>
                            <BoxView HeightRequest="1" Color="#CCCCCC"/>

                            <!-- Quality Slider -->
                            <Label Text="{Binding PhotoQuality, StringFormat='Photo Quality: {0}%'}"
                                   TextColor="#666666"
                                   FontAttributes="Bold"/>
                            <Slider Minimum="10"
                                    Maximum="100"
                                    Value="{Binding PhotoQuality}"
                                    MinimumTrackColor="{StaticResource Primary}"/>
                            <Label Text="Lower quality saves space. 75% is recommended for text readability."
                                   FontSize="11"
                                   TextColor="Gray"
                                   LineBreakMode="WordWrap"/>

                            <!-- Resolution Slider -->
                            <Label Text="{Binding MaxResolution, StringFormat='Max Resolution: {0}px'}"
                                   TextColor="#666666"
                                   FontAttributes="Bold"
                                   Margin="0,10,0,0"/>
                            <Slider Minimum="640"
                                    Maximum="3840"
                                    Value="{Binding MaxResolution}"
                                    MinimumTrackColor="{StaticResource Primary}"/>
                            <Label Text="Resizes large photos. 1280px is usually enough for AI reading."
                                   FontSize="11"
                                   TextColor="Gray"
                                   LineBreakMode="WordWrap"/>
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>

                <!-- AI -->
                <VerticalStackLayout IsVisible="{Binding IsAiTabSelected}" Spacing="20">
                    <Frame BackgroundColor="#F5F5F5" Padding="15" CornerRadius="10">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="AI Provider Settings"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#333333"/>
                            <BoxView HeightRequest="1" Color="#CCCCCC"/>

                            <Label Text="Select Provider:"
                                   TextColor="#666666"
                                   FontSize="14"
                                   FontAttributes="Bold"/>

                            <RadioButton Content="OpenRouter (Free)"
                                         Value="OpenRouter"
                                         IsChecked="{Binding IsOpenRouterSelected}"
                                         GroupName="AiProviderGroup"/>

                            <RadioButton Content="OpenAI/NIM Proxy"
                                         Value="OpenAIProxy"
                                         IsChecked="{Binding IsOpenAiProxySelected}"
                                         GroupName="AiProviderGroup"/>

                            <RadioButton Content="Z.AI (GLM-4V)"
                                         Value="ZAI"
                                         IsChecked="{Binding IsZaiSelected}"
                                         GroupName="AiProviderGroup"/>

                            <RadioButton Content="Chutes.ai"
                                         Value="Chutes"
                                         IsChecked="{Binding IsChutesSelected}"
                                         GroupName="AiProviderGroup"/>

                            <!-- OpenRouter Key Entry (Only visible if OpenRouter is selected) -->
                            <VerticalStackLayout IsVisible="{Binding IsOpenRouterSelected}" Spacing="10" Margin="20,10,0,0">
                                <Label Text="OpenRouter API Key:"
                                       FontSize="12"
                                       TextColor="#666666"/>
                                <Entry Text="{Binding OpenRouterApiKey}"
                                       Placeholder="Enter your OpenRouter API Key"
                                       IsPassword="True"
                                       BackgroundColor="White"/>
                                <Label Text="Stored locally in app preferences. You can also set OPENROUTER_API_KEY."
                                       FontSize="10"
                                       TextColor="Gray"
                                       Margin="0,5,0,0"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout IsVisible="{Binding IsOpenAiProxySelected}" Spacing="10" Margin="20,10,0,0">
                                <Label Text="Proxy Base URL:"
                                       FontSize="12"
                                       TextColor="#666666"/>
                                <Entry Text="{Binding OpenAiProxyBaseUrl}"
                                       Placeholder="http://obsidianvault.duckdns.org:3000/"
                                       BackgroundColor="White"/>
                                <Label Text="Root URL and /v1 URL both work."
                                       FontSize="10"
                                       TextColor="Gray"
                                       Margin="0,5,0,0"/>

                                <Label Text="Proxy API Key:"
                                       FontSize="12"
                                       TextColor="#666666"/>
                                <Entry Text="{Binding OpenAiProxyApiKey}"
                                       Placeholder="Enter your proxy API key"
                                       IsPassword="True"
                                       BackgroundColor="White"/>
                                <Label Text="Uses your OpenAI-compatible proxy for NIM, Chutes, Ollama, GPT4Free, and OpenRouter models."
                                       FontSize="10"
                                       TextColor="Gray"
                                       Margin="0,5,0,0"/>
                            </VerticalStackLayout>

                            <Button Text="Preload Models (Cache)"
                                    Command="{Binding PreloadModelsCommand}"
                                    BackgroundColor="White"
                                    TextColor="#333333"
                                    BorderColor="#E0E0E0"
                                    BorderWidth="1"
                                    CornerRadius="8"
                                    Margin="0,10,0,0"/>
                            <Label Text="{Binding ModelCacheStatus}"
                                   FontSize="11"
                                   TextColor="Gray"
                                   LineBreakMode="WordWrap"/>

                            <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">
                                <Switch IsToggled="{Binding CompactModelNames}"
                                        OnColor="{StaticResource Primary}"/>
                                <Label Text="Compact model names"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label Text="Shows provider/model only (hides long descriptions)."
                                   FontSize="10"
                                   TextColor="Gray"
                                   Margin="50,-5,0,0"/>

                            <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">
                                <Switch IsToggled="{Binding HideModelsOlderThanMaxAge}"
                                        OnColor="{StaticResource Primary}"/>
                                <Label Text="Hide older models"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Margin="50,-5,0,0">
                                <Label Text="Max age days"
                                       VerticalOptions="Center"
                                       FontSize="10"
                                       TextColor="Gray"/>
                                <Entry Grid.Column="1"
                                       Text="{Binding ModelMaxAgeDays}"
                                       Keyboard="Numeric"
                                       Placeholder="365"
                                       BackgroundColor="White"/>
                            </Grid>
                            <Label Text="Uses model creation dates when providers expose them. Models without dates stay visible."
                                   FontSize="10"
                                   TextColor="Gray"
                                   Margin="50,-5,0,0"/>

                            <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">
                                <Switch IsToggled="{Binding ShowG4fProxyModels}"
                                        OnColor="{StaticResource Primary}"/>
                                <Label Text="Show GPT4Free proxy models"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label Text="Off by default because GPT4Free lists can be large and include many old aliases."
                                   FontSize="10"
                                   TextColor="Gray"
                                   Margin="50,-5,0,0"/>

                            <Label Text="Hidden model IDs"
                                   TextColor="#666666"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   Margin="0,10,0,0"/>
                            <Editor Text="{Binding HiddenModelIds}"
                                    Placeholder="One model ID or wildcard per line, e.g. g4f:* or *deprecated*"
                                    AutoSize="TextChanges"
                                    MinimumHeightRequest="90"
                                    MaxLength="20000"
                                    BackgroundColor="White"/>
                            <Label Text="Matches model ID, display name, provider model ID, or owner. Supports prefix*, *suffix, and *contains*."
                                   FontSize="10"
                                   TextColor="Gray"/>

                            <Label Text="Default chat export format"
                                   TextColor="#666666"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   Margin="0,10,0,0"/>
                            <HorizontalStackLayout Spacing="10">
                                <RadioButton Content="JSON"
                                             IsChecked="{Binding IsExportFormatJson}"
                                             GroupName="ExportFormatGroup"/>
                                <RadioButton Content="Markdown"
                                             IsChecked="{Binding IsExportFormatMarkdown}"
                                             GroupName="ExportFormatGroup"/>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">
                                <Switch IsToggled="{Binding ShowConversationTokenTotal}"
                                        OnColor="{StaticResource Primary}"/>
                                <Label Text="Show token total in chat header"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label Text="Displays 'All tokens: X' at top-right of chat."
                                   FontSize="10"
                                   TextColor="Gray"
                                   Margin="50,-5,0,0"/>

                            <!-- Z.AI Key Entry (Only visible if Z.AI is selected) -->
                            <VerticalStackLayout IsVisible="{Binding IsZaiSelected}" Spacing="10" Margin="20,10,0,0">
                                <Label Text="Z.AI API Key:"
                                       FontSize="12"
                                       TextColor="#666666"/>
                                <Entry Text="{Binding ZaiApiKey}"
                                       Placeholder="Enter your Z.AI / BigModel Key"
                                       IsPassword="True"
                                       BackgroundColor="White"/>

                                <!-- Subscription Toggle -->
                                <HorizontalStackLayout Spacing="10">
                                    <Switch IsToggled="{Binding ZaiSubscriptionMode}"
                                            OnColor="{StaticResource Primary}"/>
                                    <Label Text="Use Coding Plan (Subscription)"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <Label Text="Turn ON if you pay monthly. Turn OFF if you pay per token."
                                       FontSize="10"
                                       TextColor="Gray"
                                       Margin="50,-5,0,0"/>
                            </VerticalStackLayout>

                            <!-- Chutes Key Entry (Only visible if Chutes is selected) -->
                            <VerticalStackLayout IsVisible="{Binding IsChutesSelected}" Spacing="10" Margin="20,10,0,0">
                                <Label Text="Chutes API Key:"
                                       FontSize="12"
                                       TextColor="#666666"/>
                                <Entry Text="{Binding ChutesApiKey}"
                                       Placeholder="Enter your Chutes API Key"
                                       IsPassword="True"
                                       BackgroundColor="White"/>
                                <Label Text="Chutes.ai provides decentralized AI models with vision capabilities."
                                       FontSize="10"
                                       TextColor="Gray"
                                       Margin="0,5,0,0"/>
                            </VerticalStackLayout>

                            <BoxView HeightRequest="1" Color="#CCCCCC" Margin="0,12,0,0"/>

                            <Label Text="Voice Transcription"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#333333"/>

                            <Label Text="Provider:"
                                   TextColor="#666666"
                                   FontSize="12"/>
                            <HorizontalStackLayout Spacing="16">
                                <RadioButton Content="Chutes"
                                             IsChecked="{Binding IsTranscriptionProviderChutesSelected}"
                                             GroupName="TranscriptionProviderGroup"/>
                                <RadioButton Content="OpenAI/NIM Proxy"
                                             IsChecked="{Binding IsTranscriptionProviderOpenAiProxyMultimodalSelected}"
                                             GroupName="TranscriptionProviderGroup"/>
                            </HorizontalStackLayout>

                            <Label Text="Transcription language code (e.g. en, ru, uk, de):"
                                   FontSize="12"
                                   TextColor="#666666"/>
                            <Entry Text="{Binding TranscriptionLanguage}"
                                   Placeholder="en"
                                   BackgroundColor="White"/>

                            <VerticalStackLayout IsVisible="{Binding IsOpenAiProxyMultimodalTranscriptionSelected}" Spacing="8">
                                <Label Text="Multimodal transcription model:"
                                       FontSize="12"
                                       TextColor="#666666"/>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <Picker Title="Choose multimodal proxy model"
                                            ItemsSource="{Binding MultimodalTranscriptionModels}"
                                            ItemDisplayBinding="{Binding DisplayName}"
                                            SelectedItem="{Binding SelectedMultimodalTranscriptionModel}"/>
                                    <Button Grid.Column="1"
                                            Text="Refresh"
                                            Command="{Binding RefreshMultimodalTranscriptionModelsCommand}"
                                            BackgroundColor="White"
                                            TextColor="#333333"
                                            BorderColor="#E0E0E0"
                                            BorderWidth="1"
                                            CornerRadius="8"/>
                                </Grid>
                                <Label Text="{Binding TranscriptionMultimodalModel, StringFormat='Selected model ID: {0}'}"
                                       FontSize="10"
                                       TextColor="Gray"
                                       LineBreakMode="TailTruncation"/>
                                <Label Text="Experimental: sends recorded WAV audio to the proxy chat completions endpoint using an input_audio content part."
                                       FontSize="10"
                                       TextColor="Gray"/>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>

                <!-- Integrations -->
                <VerticalStackLayout IsVisible="{Binding IsIntegrationsTabSelected}" Spacing="20">
                    <Frame BackgroundColor="#F5F5F5" Padding="15" CornerRadius="10">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Google OAuth"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#333333"/>
                            <BoxView HeightRequest="1" Color="#CCCCCC"/>

                            <!-- Android -->
                            <VerticalStackLayout Spacing="6"
                                                 IsVisible="{OnPlatform Android=True, iOS=False, WinUI=False}">
                                <Label Text="Android Client ID"
                                       FontSize="12"
                                       TextColor="#666666"/>
                                <Entry Text="{Binding AndroidClientId}"
                                       Placeholder="your-android-client-id.apps.googleusercontent.com"
                                       BackgroundColor="White"/>
                                <Label Text="Must match the build-time callback scheme in the Android project."
                                       FontSize="10"
                                       TextColor="Gray"/>
                            </VerticalStackLayout>

                            <!-- iOS -->
                            <VerticalStackLayout Spacing="6"
                                                 IsVisible="{OnPlatform iOS=True, Android=False, WinUI=False}">
                                <Label Text="iOS Client ID"
                                       FontSize="12"
                                       TextColor="#666666"/>
                                <Entry Text="{Binding IosClientId}"
                                       Placeholder="your-ios-client-id.apps.googleusercontent.com"
                                       BackgroundColor="White"/>
                            </VerticalStackLayout>

                            <!-- Windows -->
                            <VerticalStackLayout Spacing="6"
                                                 IsVisible="{OnPlatform WinUI=True, Android=False, iOS=False}">
                                <Label Text="Windows Client ID"
                                       FontSize="12"
                                       TextColor="#666666"/>
                                <Entry Text="{Binding WindowsClientId}"
                                       Placeholder="your-windows-client-id.apps.googleusercontent.com"
                                       BackgroundColor="White"/>

                                <Label Text="Windows Client Secret"
                                       FontSize="12"
                                       TextColor="#666666"
                                       Margin="0,6,0,0"/>
                                <Entry Text="{Binding WindowsClientSecret}"
                                       Placeholder="Enter your Windows client secret"
                                       IsPassword="True"
                                       BackgroundColor="White"/>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
